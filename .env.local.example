# Supabase (https://supabase.com → New Project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# GBPrimePay (https://developer.gbprimepay.com)
GBPRIMEPAY_PUBLIC_KEY=your_public_key_here
GBPRIMEPAY_SECRET_KEY=your_secret_key_here
GBPRIMEPAY_TOKEN=your_token_here

# Admin password (바꿔주세요!)
ADMIN_PASSWORD=admin1234
